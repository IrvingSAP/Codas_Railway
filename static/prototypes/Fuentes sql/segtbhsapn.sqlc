			        CCSID 284 ,
Cod_Direc_Ubicacion             FOR COLUMN CODDIU CHAR(06)
			        CCSID 284 ,
Desc_Direc_Ubicacion            FOR COLUMN DESDIU CHAR(50)
			        CCSID 284 ,
Numero_Piso                     FOR COLUMN NROPIS CHAR(02)
			        CCSID 284 ,
Cod_Cargo_Empleado              FOR COLUMN CODCAE CHAR(08)
			        CCSID 284 ,
Desc_Cargo_Empleado             FOR COLUMN DESCAE CHAR(40)
			        CCSID 284 ,
Grupo_Sanguineo                 FOR COLUMN GRUSAN CHAR(10)
			        CCSID 284 ,
Factor_RH                       FOR COLUMN RH CHAR(10)
			        CCSID 284 ,
Cod_Funcion_Empleado            FOR COLUMN CODFUN CHAR(08)
			        CCSID 284 ,
Descripcion_Funcion             FOR COLUMN DESFUN CHAR(40)
			        CCSID 284 ,
Cod_Centro_Costos               FOR COLUMN CODCCO CHAR(10)
			        CCSID 284 ,
Des_Centro_Costos               FOR COLUMN DESCCO CHAR(40)
			        CCSID 284 ,
Codigo_Pais                     FOR COLUMN CODPAI CHAR(03)
			        CCSID 284 ,
Descripcion_Pais                FOR COLUMN DESPAI CHAR(50)
			        CCSID 284 ,
Cod_Area_Empleado               FOR COLUMN CODARE CHAR(03)
			        CCSID 284 ,
Desc_Area_Empleado              FOR COLUMN DESARE CHAR(20)
			        CCSID 284 ,
Cod_Ciudad_Empleado             FOR COLUMN CODCIU CHAR(06)
			        CCSID 284 ,
Desc_Ciudad_Empleado            FOR COLUMN DESCIU CHAR(20)
			        CCSID 284 ,
Calle_Direccion                 FOR COLUMN CALLE CHAR(60)
			        CCSID 284 ,
Complemento_Direc               FOR COLUMN COMDIR CHAR(40)
			        CCSID 284 ,
Cod_Tipo_Doc_Emp                FOR COLUMN CODTDE CHAR(02)
			        CCSID 284 ,
Cod_Tipo_Doc_Jefe               FOR COLUMN CODTDJ CHAR(02)
			        CCSID 284 ,
Cod_Motivo_Ausencia             FOR COLUMN CODAUS CHAR(04)
