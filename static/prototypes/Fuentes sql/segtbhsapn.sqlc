			        CCSID 284 ,
Desc_Tipo_Doc_Jefe              FOR COLUMN TIPIDJ CHAR(40)
			        CCSID 284 ,
Docum_Id_Jefe                   FOR COLUMN NROIDJ CHAR(30)
			        CCSID 284 ,
Nombre_Jefe                     FOR COLUMN NOMJEF CHAR(40)
			        CCSID 284 ,
