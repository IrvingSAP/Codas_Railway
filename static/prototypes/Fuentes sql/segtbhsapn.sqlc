-- CreaTablas Consultas a generada
--  CREATE OR REPLACE  &LIB/SEGTBHSAPN
CREATE OR REPLACE TABLE &LIB.Tablas_Historico_Novedades_Sap
			FOR SYSTEM NAME SEGTBHSAPN(
Documento_Identidad             FOR COLUMN NROID CHAR(30)
