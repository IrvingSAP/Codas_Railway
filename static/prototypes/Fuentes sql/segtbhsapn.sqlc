Fecha_Fin_Ausencia              FOR COLUMN FEFAUS CHAR(10)
			        CCSID 284 ,
Fecha_Retiro                    FOR COLUMN FECRET CHAR(10)
			        CCSID 284 ,
Codigo_Proveedor                FOR COLUMN CODPRV CHAR(03),
			
Descrip_Proveedor               FOR COLUMN DESPRV CHAR(20),

Fecha_Importacion               FOR COLUMN FECIMP  Numeric(8),

Hora_importacion                FOR COLUMN HORIMP  Numeric(6),

Usuario_Importacion             FOR COLUMN USRIMP  Char(10)
                                CCSID 284 ,
Trabajo_Importacion             FOR COLUMN JOBIMP  Char(10)
                                CCSID 284
)
RCDFMT RSEGTBHSAP;

