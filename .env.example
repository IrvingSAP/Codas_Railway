# Copiar a .env y ajustar (el archivo .env no se versiona).
# PostgreSQL es obligatorio en local y producción (no se usa SQLite).
# Guía: docs/CODAS_DATABASE.md

DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# --- Base de datos PostgreSQL (local y producción) ---
# Opción A — URL completa (recomendada):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/codas_dev
#
# Opción B — variables sueltas (si no usa DATABASE_URL):
# DB_NAME=codas_dev
# DB_USER=codas
# DB_PASSWORD=cambiar
# DB_HOST=localhost
# DB_PORT=5432
#
# Opcionales:
# DB_CONN_MAX_AGE=600
# DB_SSLMODE=require
#
# Tests (manage.py test): si el usuario no tiene CREATEDB en PostgreSQL,
# cree la BD de prueba a mano y use --keepdb (docs/CODAS_DATABASE.md § 7).
# DB_TEST_NAME=test_codas_dev

# Producción: definir DJANGO_SECRET_KEY y DJANGO_ALLOWED_HOSTS;
# DJANGO_DEBUG=False (o omitir; production fuerza DEBUG=False).

# Huella HMAC de suscripciones (obligatorio si DEBUG=False; ver docs/CODAS_SUSCRIPCIONES_VALIDACION.md).
# LICENSE_SECRET_KEY=

# Producción (HTTPS — Railway, Render, etc.):
# CSRF_TRUSTED_ORIGINS=https://tu-proyecto.up.railway.app

# --- Correo (local, prueba/staging y producción) ---
# Producción: no definir EMAIL_BACKEND (lo asigna codas/settings/_email.py).
# EMAIL_DELIVERY:
#   auto    — Resend si hay RESEND_API_KEY; si no SMTP si hay credenciales;
#             local sin ninguno: consola; producción sin ninguno: error al arrancar
#   resend  — Resend API HTTPS (recomendado Railway Free/Hobby; https://resend.com)
#   smtp    — SMTP clásico (Gmail, Railway Pro; puertos 587 bloqueados en Railway Free)
#   console — solo consola (desarrollo)
# EMAIL_DELIVERY=auto

# --- Resend (Railway Free/Hobby y recomendado en PaaS sin SMTP saliente) ---
# RESEND_API_KEY=re_...
# DEFAULT_FROM_EMAIL=CODAS <onboarding@resend.dev>
# (producción: verificar dominio en Resend y usar remitente de ese dominio)

# --- SMTP clásico (legacy; deshabilitado en Railway Free por bloqueo de puertos) ---
# Gmail: usar contraseña de aplicación (no la contraseña normal de la cuenta).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_TIMEOUT=30
# EMAIL_HOST_USER=tu-cuenta@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=tu-cuenta@gmail.com
